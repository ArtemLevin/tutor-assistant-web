COMPOSE_PROJECT_NAME=tutor-production
APP_ENV=production
IMAGE_REPOSITORY=ghcr.io/artemlevin/tutor-assistant-web
ACTIVE_SLOT=blue
BLUE_RELEASE=v1.0.0
GREEN_RELEASE=v1.0.0
SCHEDULER_RELEASE=v1.0.0
OPS_RELEASE=v1.0.0

APP_DOMAIN=tutor.example.com
ACME_EMAIL=ops@example.com
PUBLIC_BASE_URL=https://tutor.example.com
TRUSTED_HOSTS=tutor.example.com
TRUSTED_PROXY_IPS=172.16.0.0/12
BOOTSTRAP_ORGANIZATION_NAME="Tutor Workspace"
BOOTSTRAP_ORGANIZATION_SLUG=default
BOOTSTRAP_ADMIN_EMAIL=owner@example.com
BOOTSTRAP_ADMIN_NAME="Владелец"

BBB_DEMO_MODE=false
BBB_BASE_URL=https://bbb.example.com/bigbluebutton
TRANSCRIPTION_PROVIDER=webhook
TRANSCRIPTION_WEBHOOK_URL=https://transcription.example.com/v1/transcribe
DOCUMENT_ENGINE_PROVIDER=latex-for-everyone
DOCUMENT_ENGINE_URL=https://latex.example.com

ARTIFACT_S3_ENDPOINT_URL=http://minio:9000
ARTIFACT_S3_REGION=us-east-1
ARTIFACT_S3_BUCKET=tutor-artifacts
BACKUP_S3_BUCKET=tutor-backups
BACKUP_S3_PREFIX=tutor-assistant
# For host-level disaster recovery, point these at an off-host S3 service.
# The MinIO defaults keep the first staging deployment self-contained.
BACKUP_S3_ENDPOINT_URL=http://minio:9000
BACKUP_S3_REGION=us-east-1
BACKUP_S3_ACCESS_KEY=tutor-app
ARTIFACT_RETENTION_DAYS=365
BACKUP_RETENTION_DAYS=35
BACKUP_INTERVAL_SECONDS=79200

SENTRY_ENVIRONMENT=production
OTEL_SERVICE_NAME=tutor-assistant-web
GRAFANA_ADMIN_USER=admin
# Optional HTTPS Alertmanager webhook; configure it before production approval.
ALERT_WEBHOOK_URL=
POSTGRES_DB=tutor
POSTGRES_USER=tutor
MINIO_ROOT_USER=tutor-root
S3_APP_ACCESS_KEY=tutor-app
