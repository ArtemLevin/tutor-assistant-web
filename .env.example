APP_NAME=Tutor Assistant
APP_ENV=development
APP_SECRET_KEY=replace-with-a-long-random-value
APP_TIMEZONE=Europe/Moscow
PUBLIC_BASE_URL=http://localhost:8000
BOOTSTRAP_ORGANIZATION_NAME=Tutor Workspace
BOOTSTRAP_ORGANIZATION_SLUG=default
BOOTSTRAP_ADMIN_EMAIL=admin@localhost
BOOTSTRAP_ADMIN_NAME=Администратор
BOOTSTRAP_ADMIN_PASSWORD=change-this-password
INVITATION_TTL_HOURS=72

# Local default. Docker Compose overrides this with PostgreSQL.
DATABASE_URL=sqlite:///./data/tutor-assistant.db
AUTO_MIGRATE=true
DATABASE_POOL_SIZE=10
DATABASE_MAX_OVERFLOW=20
DATABASE_POOL_TIMEOUT=30
DATABASE_POOL_RECYCLE=1800
DATABASE_STATEMENT_TIMEOUT_MS=30000
DATABASE_LOCK_TIMEOUT_MS=5000
REDIS_URL=redis://localhost:6379/0
TASK_EAGER=true
CELERY_VISIBILITY_TIMEOUT=10800
WORKER_SHUTDOWN_TIMEOUT=30

# Demo mode lets the full UI run without a BigBlueButton server.
BBB_DEMO_MODE=true
BBB_BASE_URL=https://bbb.example.com
BBB_SECRET=replace-with-bbb-shared-secret
BBB_REQUEST_TIMEOUT=15

# auto selects demo in BBB demo mode and webhook when its URL is configured.
# For local speech recognition: uv sync --extra transcription, then use faster-whisper.
TRANSCRIPTION_PROVIDER=auto
TRANSCRIPTION_MODEL=small
TRANSCRIPTION_LANGUAGE=ru
TRANSCRIPTION_DEVICE=cpu
TRANSCRIPTION_COMPUTE_TYPE=int8
TRANSCRIPTION_WEBHOOK_URL=
TRANSCRIPTION_WEBHOOK_TOKEN=
TRANSCRIPTION_REQUEST_TIMEOUT=300
TRANSCRIPTION_MAX_DOWNLOAD_MB=500

WORKFLOW_MAX_RETRIES=5
WORKFLOW_MAX_ATTEMPTS=6
WORKFLOW_RETRY_BASE_SECONDS=30
WORKFLOW_RETRY_MAX_SECONDS=3600
WORKFLOW_SOFT_TIME_LIMIT=7200
WORKFLOW_HARD_TIME_LIMIT=7500
JOB_LEASE_SECONDS=300
JOB_RECOVERY_POLL_SECONDS=30
JOB_RECOVERY_BATCH_SIZE=100
OUTBOX_BATCH_SIZE=20
OUTBOX_POLL_SECONDS=10
OUTBOX_MAX_ATTEMPTS=12
OUTBOX_DISPATCH_LEASE_SECONDS=300
CIRCUIT_BREAKER_FAILURE_THRESHOLD=5
CIRCUIT_BREAKER_RECOVERY_SECONDS=60

# Optional automation endpoint. See docs/materials-webhook.md.
MATERIALS_WEBHOOK_URL=
MATERIALS_WEBHOOK_TOKEN=
MATERIALS_REQUEST_TIMEOUT=60

# Versioned document factory. "local" creates deterministic development previews.
# "latex-for-everyone" compiles PDF through POST /api/compile/raw.
DOCUMENT_ENGINE_PROVIDER=local
DOCUMENT_ENGINE_URL=http://localhost:8080
DOCUMENT_ENGINE_TOKEN=
DOCUMENT_ENGINE_TIMEOUT=120
DOCUMENT_MAX_PDF_MB=50
ARTIFACT_STORAGE_ROOT=./data/artifacts
ARTIFACT_STORAGE_PROVIDER=local
# Production / Docker Compose:
# ARTIFACT_STORAGE_PROVIDER=s3
# ARTIFACT_S3_ENDPOINT_URL=http://minio:9000
# ARTIFACT_S3_REGION=us-east-1
# ARTIFACT_S3_BUCKET=tutor-artifacts
# ARTIFACT_S3_ACCESS_KEY=tutor-minio
# ARTIFACT_S3_SECRET_KEY=tutor-minio-secret
# ARTIFACT_S3_SERVER_SIDE_ENCRYPTION=auto
# ARTIFACT_CLAMAV_ENABLED=true
ARTIFACT_MAX_SIZE_MB=500
ARTIFACT_RETENTION_DAYS=365
ARTIFACT_DELETE_GRACE_DAYS=30
ARTIFACT_ABORT_MULTIPART_DAYS=1

SEED_DEMO_DATA=true
SESSION_COOKIE_SECURE=false

# Empty means all built-in modules. Example: identity,students,scheduling
ENABLED_MODULES=
